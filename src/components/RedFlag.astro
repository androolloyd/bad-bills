---
const { item } = Astro.props;
const b = item.b;
const RISK_LABEL = { high: 'High concern', medium: 'Watch closely', low: 'Lower concern', positive: 'Rights-positive' };
const stCls = b.st === 'law' ? 'pill-law' : b.st === 'stall' ? 'pill-stall' : 'pill-move';
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(b.num + ' — ' + b.title)}&url=${encodeURIComponent('https://badbills.ca/b/' + item.slug)}`;
---
<article class="rf">
  <div class="rf-head"><span class="rf-num">{b.num}</span><span class={`badge b-${b.risk}`}>{RISK_LABEL[b.risk]}</span></div>
  <h3>{b.title}</h3>
  <div style="margin:-4px 0 10px"><span class={`pill ${stCls}`}>{b.status}</span></div>
  {item.vote && <div class="vote-line">🗳️ {item.vote.result} {item.vote.yea}–{item.vote.nay} <span class="muted" style="font-weight:600">· {item.vote.stage}</span></div>}
  <p class="blurb">{b.sum}</p>
  <h4>✅ The case for</h4><p class="for">{b.forr}</p>
  <h4>⚠️ The case against</h4><p class="against">{b.against}</p>
  <div class="priv"><b>🔐 Privacy &amp; civil liberties:</b> {b.priv}</div>
  <h4 style="margin-top:12px">👥 Who it affects</h4><p class="for">{b.who}</p>
  <p style="margin-top:12px"><a href={xUrl} target="_blank" rel="noopener">𝕏 Share</a> &nbsp;·&nbsp; <a href={`/b/${item.slug}`}>📚 Sources &amp; commentary →</a></p>
</article>
